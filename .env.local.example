# BookScanner Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Gemini API (for Mood Search) - DEPRECATED, now using OpenRouter
# GEMINI_API_KEY=your_gemini_api_key

# OpenRouter API (for AI Mood-based recommendations - uses DeepSeek-R1)
OPENROUTER_API_KEY=your_openrouter_api_key

# Cloudflare R2 (Optional - for image storage)
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=bookscanner-covers
